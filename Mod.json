{
    "id": "yourname.cbf-beyond",
    "name": "CBF Beyond",
    "version": "v1.0.0",
    "developer": "YourName",
    "description": "Click Beyond Frames. Removes the 480 TPS limit from RobTop's official CBF implementation for maximum input precision.",
    "tags": ["gameplay", "performance", "utility", "android"],
    "geode": "v1.8.0",
    "gd": "2.208",
    "platforms": ["android"],
    
    "settings": {
        "cbf-enabled": {
            "name": "Enable CBF",
            "description": "Toggle Click Beyond Frames on/off",
            "type": "bool",
            "default": true
        },
        "polling-rate": {
            "name": "Polling Rate (Hz)",
            "description": "Higher = more precise, uses more CPU. Vanilla cap is 480.",
            "type": "int",
            "default": 1000,
            "min": 60,
            "max": 2000
        }
    },

    "api": {
        "include": ["include/CBFBeyond"]
    }
}
