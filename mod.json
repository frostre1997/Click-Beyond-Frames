{
    "id": "frostre1997.click-beyond-frames",
    "name": "Click Beyond Frames",
    "version": "v1.0.0",
    "developer": "frostre1997",
    "description": "Removes the 480 TPS cap from RobTop's official CBF for unlimited input precision on Android.",
    "geode": "5.8.1",
    "gd": {
        "win": "2.2081",
        "android": "2.2081",
        "mac": "2.2081",
        "ios": "2.2081"
    },
    "tags": ["gameplay", "performance", "utility", "android"],
    "platforms": ["android"],
    "dependencies": {
        "frostre1997.click-beyond-frames-api": {
            "version": ">=v1.0.0",
            "required": true
        }
    },
    "settings": {
        "cbf-enabled": {
            "name": "Enable Click Beyond Frames",
            "description": "Toggle the mod on/off",
            "type": "bool",
            "default": true
        },
        "polling-rate": {
            "name": "Polling Rate (Hz)",
            "description": "Higher = more precise. Vanilla cap is 480.",
            "type": "int",
            "default": 1000,
            "min": 60,
            "max": 2000
        }
    }
}
