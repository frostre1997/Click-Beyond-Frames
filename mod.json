{
    "geode": "5.0.0",
    "version": "1.0.0",
    "gd": {
        "win": "2.2081",
        "android": "2.2081",
        "mac": "2.2081",
        "ios": "2.2081"
    },
    "id": "clickbeyondframes",
    "name": "ClickBeyondFrames",
    "developer": "frostre1997",
    "description": "Click Beyond Frames with customizable FPS/TPS counter",
    "settings": {
        "cbf-enabled": {
            "name": "Enable CBF",
            "type": "bool",
            "default": true
        },
        "polling-rate": {
            "name": "Polling Rate (Hz)",
            "type": "int",
            "default": 1000,
            "min": 60,
            "max": 2000
        },
        "show-counter": {
            "name": "Show Counter",
            "type": "bool",
            "default": true
        },
        "counter-scale": {
            "name": "Counter Scale",
            "type": "float",
            "default": 0.5,
            "min": 0.3,
            "max": 2.0
        },
        "counter-pos-x": {
            "name": "Position X Offset",
            "type": "float",
            "default": 0.0,
            "min": -500.0,
            "max": 500.0
        },
        "counter-pos-y": {
            "name": "Position Y Offset",
            "type": "float",
            "default": 0.0,
            "min": -500.0,
            "max": 500.0
        },
        "show-fps": {
            "name": "Show FPS",
            "type": "bool",
            "default": true
        },
        "show-tps": {
            "name": "Show TPS",
            "type": "bool",
            "default": true
        },
        "counter-color": {
            "name": "Counter Color",
            "type": "int",
            "default": 0,
            "min": 0,
            "max": 3,
            "description": "0=White, 1=Green, 2=Yellow, 3=Red"
        }
    }
}
